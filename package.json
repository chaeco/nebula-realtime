{
  "name": "nebula-realtime-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo for Nebula Realtime server and client packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run clean && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "ops:env": "node scripts/ops/validate-env.mjs",
    "ops:preflight": "node scripts/ops/preflight.mjs",
    "ops:smoke": "node scripts/ops/smoke-test.mjs"
  },
  "author": "chaeco",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaeco/nebula-realtime.git"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "@types/node": "^20.11.16",
    "@cloudflare/workers-types": "^4.20240222.0",
    "wrangler": "^3.30.1"
  }
}